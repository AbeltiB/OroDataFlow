generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Station {
  id          String       @id @default(cuid())
  name        String       @unique
  arrivals    Arrival[]
  tripRecords TripRecord[]
  createdAt   DateTime     @default(now())
}

model Arrival {
  id          String       @id @default(cuid())
  name        String
  stationId   String
  station     Station      @relation(fields: [stationId], references: [id], onDelete: Cascade)
  tripRecords TripRecord[]
  createdAt   DateTime     @default(now())

  @@unique([name, stationId])
}

model Employee {
  id          String       @id @default(cuid())
  name        String       @unique
  tripRecords TripRecord[]
  createdAt   DateTime     @default(now())
}

model TripRecord {
  id          String    @id @default(cuid())
  csvBackupId String
  csvBackup   CsvBackup @relation(fields: [csvBackupId], references: [id])

  departure    String
  arrival      String
  tripDate     DateTime

  // Computed / enhanced fields
  plate            String?  // "OR-3-61253" (plateCode + plateNo concatenated)
  associationName  String?  // "Yenyaa" (stripped from "Yenyaa-1")
  associationLevel String?  // "1" (extracted from "Yenyaa-1")
  serviceChargeSum Float?   // serviceCharge * passengers

  // Original CSV fields
  plateNo       String
  plateCode     String
  level         String   // "Level 1" / "Level 2" / "Level 3"
  fleetType     String   // "Midbus" / "Minibus"
  association   String   // raw association string
  passengers    Int
  tariff        Float
  serviceCharge Float
  tripDistance  Float
  employeeName  String
  total         Float

  // Relations (nullable — populated by pipeline, backfilled over time)
  stationId    String?
  arrivalRefId String?
  employeeId   String?
  station      Station?  @relation(fields: [stationId], references: [id])
  arrivalRef   Arrival?  @relation(fields: [arrivalRefId], references: [id])
  employee     Employee? @relation(fields: [employeeId], references: [id])

  importedAt DateTime @default(now())

  @@index([tripDate])
  @@index([departure, arrival])
  @@index([association])
  @@index([associationName])
  @@index([fleetType])
  @@index([level])
  @@index([stationId])
  @@index([employeeId])
  @@index([csvBackupId])
}

model CsvBackup {
  id           String       @id @default(cuid())
  filename     String
  reportDate   String
  rowCount     Int
  source       String
  downloadedAt DateTime     @default(now())
  trips        TripRecord[]

  @@index([reportDate])
}

model RunLog {
  id             String    @id @default(cuid())
  triggeredBy    String
  status         String
  stage          String?
  error          String?
  csvBackupId    String?
  excelFile      String?
  rowCount       Int?
  sentToTelegram String[]
  sentToEmail    String[]
  startedAt      DateTime  @default(now())
  finishedAt     DateTime?

  @@index([startedAt])
  @@index([status])
}

model Recipient {
  id        String   @id @default(cuid())
  name      String
  chatId    String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model EmailRecipient {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model AppConfig {
  id            String   @id @default("singleton")
  cronEnabled   Boolean  @default(false)
  cronTime      String   @default("08:00")
  timezone      String   @default("Africa/Addis_Ababa")
  weeklyEnabled Boolean  @default(true)
  weeklyDay     Int      @default(1)
  weeklyTime    String   @default("07:00")
  updatedAt     DateTime @updatedAt
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}
